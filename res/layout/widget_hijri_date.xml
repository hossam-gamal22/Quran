<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/widget_hijri_date.xml -->
<!-- تخطيط ويدجت التاريخ الهجري - روح المسلم -->
<!-- يستخدم ImageView بدلاً من TextView لعرض خط Amiri العربي -->

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background_hijri"
    android:gravity="center">

    <!-- اسم اليوم (Bitmap) -->
    <ImageView
        android:id="@+id/iv_day_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="اسم اليوم" />

    <!-- اليوم الهجري (Bitmap) -->
    <ImageView
        android:id="@+id/iv_hijri_day"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="اليوم الهجري" />

    <!-- الشهر الهجري (Bitmap) -->
    <ImageView
        android:id="@+id/iv_hijri_month"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="الشهر الهجري" />

    <!-- السنة الهجرية (Bitmap) -->
    <ImageView
        android:id="@+id/iv_hijri_year"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:contentDescription="السنة الهجرية" />

    <!-- التاريخ الميلادي (Bitmap) -->
    <ImageView
        android:id="@+id/iv_gregorian_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        android:contentDescription="التاريخ الميلادي" />

</LinearLayout>
