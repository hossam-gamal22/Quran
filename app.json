{
  "expo": {
    "name": "روح المسلم",
    "slug": "rooh-almuslim",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icons/icon.png",
    "scheme": "rooh-almuslim",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icons/splash-icon_en.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rooh.almuslim",
      "buildNumber": "1",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["whatsapp"],
        "GADApplicationIdentifier": "ca-app-pub-3645278220050673~7902167287",
        "NSSupportsLiveActivities": true,
        "NSLocationWhenInUseUsageDescription": "نحتاج الموقع لتحديد اتجاه القبلة وأوقات الصلاة",
        "NSLocationAlwaysUsageDescription": "نحتاج الموقع لتحديد اتجاه القبلة وأوقات الصلاة",
        "UIBackgroundModes": ["audio", "fetch", "remote-notification"],
        "SKAdNetworkItems": [
          { "SKAdNetworkIdentifier": "cstr6suwn9.skadnetwork" },
          { "SKAdNetworkIdentifier": "4fzdc2evr5.skadnetwork" },
          { "SKAdNetworkIdentifier": "2fnua5tdw4.skadnetwork" },
          { "SKAdNetworkIdentifier": "ydx93a7ass.skadnetwork" },
          { "SKAdNetworkIdentifier": "5a6flpkh64.skadnetwork" }
        ],
        "NSUserTrackingUsageDescription": "يستخدم هذا التطبيق معرف الإعلانات لعرض إعلانات مخصصة"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icons/android-icon-foreground.png",
        "backgroundImage": "./assets/images/icons/android-icon-background.png",
        "monochromeImage": "./assets/images/icons/android-icon-monochrome.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.rooh.almuslim",
      "versionCode": 1,
      "permissions": [
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "SCHEDULE_EXACT_ALARM",
        "POST_NOTIFICATIONS"
      ],
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "rooh-almuslim" }
          ],
          "category": ["DEFAULT", "BROWSABLE"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icons/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icons/notification-icon.png",
          "color": "#10B981",
          "androidMode": "default",
          "androidCollapsedTitle": "روح المسلم"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "نحتاج الموقع لتحديد اتجاه القبلة وأوقات الصلاة"
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "نحتاج إذن الحركة لتحديد اتجاه القبلة"
        }
      ],
      "expo-asset",
      "expo-localization",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3645278220050673~7902167287",
          "iosAppId": "ca-app-pub-3645278220050673~7902167287"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "12ffec15-6357-43b4-a309-8e71cc2afc8c"
      }
    },
    "owner": "hossam-gamal22",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/12ffec15-6357-43b4-a309-8e71cc2afc8c",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    }
  }
}
