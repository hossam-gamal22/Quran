{
  "expo": {
    "name": "روح المسلم",
    "slug": "rooh-almuslim",
    "version": "1.0.4",
    "orientation": "default",
    "icon": "./assets/images/icons/icon.png",
    "scheme": "rooh-almuslim",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icons/App-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rooh.almuslim",
      "buildNumber": "5",
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.roohmuslim.app"]
      },
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["whatsapp"],
        "GADApplicationIdentifier": "ca-app-pub-3645278220050673~7902167287",
        "NSSupportsLiveActivities": true,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsArbitraryLoadsForMedia": true
        },
        "NSLocationWhenInUseUsageDescription": "نحتاج الموقع لتحديد اتجاه القبلة وأوقات الصلاة",
        "NSLocationAlwaysUsageDescription": "نحتاج الموقع لتحديد اتجاه القبلة وأوقات الصلاة",
        "UIBackgroundModes": ["audio", "fetch", "remote-notification"],
        "SKAdNetworkItems": [
          { "SKAdNetworkIdentifier": "cstr6suwn9.skadnetwork" },
          { "SKAdNetworkIdentifier": "4fzdc2evr5.skadnetwork" },
          { "SKAdNetworkIdentifier": "2fnua5tdw4.skadnetwork" },
          { "SKAdNetworkIdentifier": "ydx93a7ass.skadnetwork" },
          { "SKAdNetworkIdentifier": "5a6flpkh64.skadnetwork" }
        ],
        "NSUserTrackingUsageDescription": "يستخدم هذا التطبيق معرف الإعلانات لعرض إعلانات مخصصة"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icons/android-icon-foreground.png",
        "backgroundImage": "./assets/images/icons/android-icon-background.png",
        "monochromeImage": "./assets/images/icons/android-icon-monochrome.png"
      },
      "package": "com.rooh.almuslim",
      "versionCode": 5,
      "permissions": [
        "INTERNET",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "POST_NOTIFICATIONS",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
      ],
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "rooh-almuslim" }
          ],
          "category": ["DEFAULT", "BROWSABLE"]
        }
      ]
    },
    "notification": {
      "icon": "./assets/images/icons/notification-icon.png",
      "color": "#22c55e",
      "androidMode": "default"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icons/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icons/notification-icon.png",
          "color": "#22c55e",
          "androidMode": "default",
          "androidCollapsedTitle": "روح المسلم",
          "sounds": [
            "./assets/sounds/notifications/general_reminder.mp3",
            "./assets/sounds/notifications/salawat.mp3",
            "./assets/sounds/notifications/istighfar.mp3",
            "./assets/sounds/notifications/tasbih.mp3",
            "./assets/sounds/notifications/subhanallah.mp3",
            "./assets/sounds/notifications/alhamdulillah.mp3",
            "./assets/sounds/notifications/morning_adhkar.mp3",
            "./assets/sounds/notifications/evening_adhkar.mp3",
            "./assets/sounds/adhan/makkah.mp3",
            "./assets/sounds/adhan/madinah.mp3",
            "./assets/sounds/adhan/alaqsa.mp3",
            "./assets/sounds/adhan/mishary.mp3",
            "./assets/sounds/adhan/abdulbasit.mp3",
            "./assets/sounds/adhan/sudais.mp3",
            "./assets/sounds/adhan/egypt.mp3",
            "./assets/sounds/adhan/dosari.mp3",
            "./assets/sounds/adhan/ajman.mp3",
            "./assets/sounds/adhan/ali_mulla.mp3",
            "./assets/sounds/adhan/naqshbandi.mp3",
            "./assets/sounds/adhan/sharif.mp3",
            "./assets/sounds/adhan/mansoor_zahrani.mp3",
            "./assets/sounds/adhan/haramain.mp3",
            "./assets/sounds/adhan/silent.mp3"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "نحتاج الموقع لتحديد اتجاه القبلة وأوقات الصلاة"
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "نحتاج إذن الحركة لتحديد اتجاه القبلة"
        }
      ],
      "expo-asset",
      "expo-localization",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3645278220050673~7902167287",
          "iosAppId": "ca-app-pub-3645278220050673~7902167287"
        }
      ],
      [
        "react-native-android-widget",
        {
          "fonts": [
            "./assets/fonts/Amiri-Regular.ttf",
            "./assets/fonts/Amiri-Bold.ttf"
          ],
          "widgets": [
            {
              "name": "PrayerTimesSmall",
              "label": "الصلاة القادمة",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "description": "عرض الصلاة القادمة والعد التنازلي",
              "updatePeriodMillis": 1800000,
              "previewImage": "./assets/images/icons/icon.png"
            },
            {
              "name": "PrayerTimesMedium",
              "label": "مواقيت الصلاة",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "description": "عرض جميع مواقيت الصلاة",
              "updatePeriodMillis": 1800000,
              "previewImage": "./assets/images/icons/icon.png"
            },
            {
              "name": "DailyVerseSmall",
              "label": "آية اليوم",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "description": "آية من القرآن الكريم يوميًا",
              "updatePeriodMillis": 1800000,
              "previewImage": "./assets/images/icons/icon.png"
            },
            {
              "name": "DailyVerseMedium",
              "label": "آية اليوم",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "description": "آية من القرآن الكريم مع اسم السورة",
              "updatePeriodMillis": 1800000,
              "previewImage": "./assets/images/icons/icon.png"
            },
            {
              "name": "DailyDhikrSmall",
              "label": "ذكر اليوم",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "description": "ذكر يومي للتذكير",
              "updatePeriodMillis": 1800000,
              "previewImage": "./assets/images/icons/icon.png"
            },
            {
              "name": "DailyDhikrMedium",
              "label": "ذكر اليوم",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "description": "ذكر اليوم مع المصدر",
              "updatePeriodMillis": 1800000,
              "previewImage": "./assets/images/icons/icon.png"
            },
            {
              "name": "AzkarProgressSmall",
              "label": "الأذكار اليومية",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "description": "تتبع أذكار الصباح والمساء",
              "updatePeriodMillis": 1800000,
              "previewImage": "./assets/images/icons/icon.png"
            },
            {
              "name": "AzkarProgressMedium",
              "label": "الأذكار اليومية",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "description": "تقدم أذكار الصباح والمساء",
              "updatePeriodMillis": 1800000,
              "previewImage": "./assets/images/icons/icon.png"
            },
            {
              "name": "HijriDateSmall",
              "label": "التاريخ الهجري",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "description": "عرض التاريخ الهجري",
              "updatePeriodMillis": 1800000,
              "previewImage": "./assets/images/icons/icon.png"
            },
            {
              "name": "HijriDateMedium",
              "label": "التاريخ الهجري",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "description": "التاريخ الهجري والميلادي",
              "updatePeriodMillis": 1800000,
              "previewImage": "./assets/images/icons/icon.png"
            }
          ]
        }
      ],
      "./plugins/with-ios-widgets",
      "./plugins/with-android-gradle-fix",
      ["./plugins/with-notification-large-icon", { "icon": "./assets/images/icons/icon.png" }]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "12ffec15-6357-43b4-a309-8e71cc2afc8c"
      }
    },
    "owner": "hossamgamal",
    "runtimeVersion": "1.0.3",
    "updates": {
      "url": "https://u.expo.dev/12ffec15-6357-43b4-a309-8e71cc2afc8c",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    }
  }
}
