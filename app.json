{
  "expo": {
    "name": "روح المسلم",
    "slug": "rooh-almuslim",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "rooh-almuslim",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rooh.almuslim",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "نحتاج الموقع لتحديد اتجاه القبلة وأوقات الصلاة",
        "NSLocationAlwaysUsageDescription": "نحتاج الموقع لتحديد اتجاه القبلة وأوقات الصلاة",
        "UIBackgroundModes": ["audio", "fetch", "remote-notification"],
        "SKAdNetworkItems": [
          { "SKAdNetworkIdentifier": "cstr6suwn9.skadnetwork" },
          { "SKAdNetworkIdentifier": "4fzdc2evr5.skadnetwork" },
          { "SKAdNetworkIdentifier": "2fnua5tdw4.skadnetwork" },
          { "SKAdNetworkIdentifier": "ydx93a7ass.skadnetwork" },
          { "SKAdNetworkIdentifier": "5a6flpkh64.skadnetwork" },
          { "SKAdNetworkIdentifier": "p78aez5w95.skadnetwork" },
          { "SKAdNetworkIdentifier": "v72qych5uu.skadnetwork" },
          { "SKAdNetworkIdentifier": "c6k4g5qg8m.skadnetwork" },
          { "SKAdNetworkIdentifier": "s39g8k73mm.skadnetwork" },
          { "SKAdNetworkIdentifier": "3qy4746246.skadnetwork" }
        ],
        "NSUserTrackingUsageDescription": "يستخدم هذا التطبيق معرف الإعلانات لعرض إعلانات مخصصة"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.rooh.almuslim",
      "versionCode": 1,
      "permissions": [
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "SCHEDULE_EXACT_ALARM",
        "POST_NOTIFICATIONS",
        "com.google.android.gms.permission.AD_ID"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#10B981",
          "sounds": ["./assets/sounds/adhan.wav", "./assets/sounds/notification.wav"],
          "androidMode": "default",
          "androidCollapsedTitle": "روح المسلم"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "نحتاج الموقع لتحديد اتجاه القبلة وأوقات الصلاة"
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "نحتاج إذن الحركة لتحديد اتجاه القبلة"
        }
      ],
      "expo-asset",
      "expo-localization",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6103597967254377~4576655042",
          "iosAppId": "ca-app-pub-6103597967254377~2134799890"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "12ffec15-6357-43b4-a309-8e71cc2afc8c"
      }
    },
    "owner": "hossam-gamal22",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/12ffec15-6357-43b4-a309-8e71cc2afc8c",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "locales": {
      "ar": "./locales/ar.json",
      "en": "./locales/en.json"
    }
  }
}
