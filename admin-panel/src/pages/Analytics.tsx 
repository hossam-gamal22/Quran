              أكثر الخصائص استخداماً
            </h3>
            <div className="grid grid-cols-2 md:grid-cols-3 gap-4">
              {content.mostUsedFeatures.map((feature, i) => {
                const icons: Record<string, React.ReactNode> = {
                  azkar: <Moon className="w-6 h-6" />,
                  quran: <BookOpen className="w-6 h-6" />,
                  prayer: <Clock className="w-6 h-6" />,
                  qibla: <MapPin className="w-6 h-6" />,
                  tasbih: <Star className="w-6 h-6" />,
                  dua: <Heart className="w-6 h-6" />,
