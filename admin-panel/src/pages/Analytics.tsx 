                    <div className="flex-1">
                      <p className="font-medium text-gray-800">{feature.name}</p>
                      <p className="text-sm text-gray-500">{feature.count.toLocaleString()}</p>
                    </div>
                    <span className="text-lg font-bold text-gray-400">{feature.percentage}%</span>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      )}

      {/* تبويب المستخدمين */}
      {activeTab === 'users' && (
        <div className="space-y-6">
          {/* التوزيع الجغرافي */}
