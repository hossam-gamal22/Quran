                const colors = ['bg-purple-100 text-purple-600', 'bg-emerald-100 text-emerald-600', 'bg-blue-100 text-blue-600', 'bg-red-100 text-red-600', 'bg-amber-100 text-amber-600', 'bg-pink-100 text-pink-600'];
                
                return (
                  <div key={i} className="flex items-center gap-3 p-4 bg-gray-50 rounded-xl">
                    <div className={`p-2 rounded-lg ${colors[i]}`}>
                      {icons[feature.feature]}
