            <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
              {demographics.byCountry.slice(0, 8).map((country, i) => (
                <div key={i} className="flex items-center gap-3 p-3 bg-gray-50 rounded-lg">
                  <span className="text-2xl"><CountryFlag code={country.country} /></span>
                  <div className="flex-1">
                    <p className="font-medium text-sm">{country.countryAr}</p>
                    <p className="text-xs text-gray-500">{country.percentage}%</p>
                  </div>
                  <span className="font-bold text-gray-700">{country.count.toLocaleString()}</span>
                </div>
              ))}
            </div>
          </div>

          {/* اللغات */}
          <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div className="bg-white p-6 rounded-xl shadow-sm border">
              <h3 className="font-bold text-gray-800 mb-4 flex items-center gap-2">
                <Globe className="w-5 h-5 text-blue-600" />
                اللغات
              </h3>
              <div className="space-y-3">
                {demographics.byLanguage.map((lang, i) => (
                  <div key={i}>
                    <div className="flex items-center justify-between mb-1">
                      <span className="font-medium">{lang.language}</span>
                      <span className="text-sm text-gray-500">{lang.percentage}%</span>
                    </div>
                    <ProgressBar
                      value={lang.percentage}
                      max={100}
                      color={i === 0 ? 'bg-emerald-500' : i === 1 ? 'bg-blue-500' : 'bg-gray-400'}
