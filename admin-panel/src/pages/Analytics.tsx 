// ==================== المكون الرئيسي ====================

const AnalyticsPage: React.FC = () => {
  const [activeTab, setActiveTab] = useState<'overview' | 'engagement' | 'content' | 'users' | 'realtime'>('overview');
  const [dateRange, setDateRange] = useState<DateRange>('month');
  const [isLoading, setIsLoading] = useState(true);
  const [isRefreshing, setIsRefreshing] = useState(false);
  const [lastUpdated, setLastUpdated] = useState<Date>(new Date());
  
  // البيانات
  const [overview, setOverview] = useState<OverviewStats>(MOCK_OVERVIEW);
  const [engagement, setEngagement] = useState<EngagementStats>(MOCK_ENGAGEMENT);
  const [content, setContent] = useState<ContentStats>(MOCK_CONTENT);
  const [demographics, setDemographics] = useState<UserDemographics>(MOCK_DEMOGRAPHICS);
  const [growth, setGrowth] = useState<GrowthData>(MOCK_GROWTH);
  const [realtime, setRealtime] = useState<RealtimeData>(MOCK_REALTIME);

  // تحميل البيانات
  useEffect(() => {
    loadData();
  }, [dateRange]);

  // تحديث البيانات الفورية
  useEffect(() => {
    const interval = setInterval(() => {
      if (activeTab === 'realtime') {
        updateRealtimeData();
      }
    }, 5000); // كل 5 ثواني

    return () => clearInterval(interval);
  }, [activeTab]);

  const loadData = async () => {
    setIsLoading(true);
    // محاكاة API call
    await new Promise(resolve => setTimeout(resolve, 1000));
    setIsLoading(false);
    setLastUpdated(new Date());
  };

  const refreshData = async () => {
    setIsRefreshing(true);
    await new Promise(resolve => setTimeout(resolve, 800));
    setIsRefreshing(false);
    setLastUpdated(new Date());
  };

  const updateRealtimeData = () => {
    // محاكاة تحديث البيانات الفورية
    setRealtime(prev => ({
      ...prev,
      activeNow: prev.activeNow + Math.floor(Math.random() * 10) - 5,
      lastHourSessions: prev.lastHourSessions + Math.floor(Math.random() * 20),
    }));
  };

  const exportData = () => {
    const data = {
      overview,
      engagement,
      content,
      demographics,
      growth,
      exportDate: new Date().toISOString(),
      dateRange
    };
    const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `analytics-${dateRange}-${new Date().toISOString().split('T')[0]}.json`;
    a.click();
  };

  if (isLoading) {
    return (
      <div className="flex items-center justify-center h-64">
        <Loader2 className="w-8 h-8 animate-spin text-emerald-600" />
        <span className="mr-2 text-gray-600">جاري تحميل التحليلات...</span>
      </div>
    );
  }

  return (
    <div className="p-6 max-w-7xl mx-auto" dir="rtl">
      {/* الرأس */}
      <div className="flex items-center justify-between mb-6">
        <div>
          <h1 className="text-2xl font-bold text-gray-800 flex items-center gap-2">
            <BarChart3 className="w-7 h-7 text-emerald-600" />
            التحليلات والإحصائيات
          </h1>
          <p className="text-gray-500 mt-1">
            آخر تحديث: {lastUpdated.toLocaleTimeString('ar-EG')}
          </p>
        </div>
        <div className="flex items-center gap-3">
          {/* فلتر الفترة */}
          <select
            value={dateRange}
            onChange={(e) => setDateRange(e.target.value as DateRange)}
            className="px-4 py-2 border rounded-lg focus:ring-2 focus:ring-emerald-500"
          >
            <option value="today">اليوم</option>
            <option value="yesterday">أمس</option>
            <option value="week">آخر 7 أيام</option>
            <option value="month">آخر 30 يوم</option>
            <option value="quarter">آخر 3 أشهر</option>
            <option value="year">آخر سنة</option>
            <option value="all">الكل</option>
          </select>
          
          <button
            onClick={refreshData}
            disabled={isRefreshing}
            className="flex items-center gap-2 px-4 py-2 text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200"
          >
            <RefreshCw className={`w-4 h-4 ${isRefreshing ? 'animate-spin' : ''}`} />
            تحديث
          </button>
          
          <button
            onClick={exportData}
            className="flex items-center gap-2 px-4 py-2 text-white bg-emerald-600 rounded-lg hover:bg-emerald-700"
          >
            <Download className="w-4 h-4" />
            تصدير
          </button>
        </div>
      </div>

      {/* التبويبات */}
      <div className="flex gap-2 mb-6 border-b pb-2 overflow-x-auto">
        {[
          { id: 'overview', label: 'نظرة عامة', icon: PieChart },
          { id: 'engagement', label: 'التفاعل', icon: Activity },
          { id: 'content', label: 'المحتوى', icon: BookOpen },
          { id: 'users', label: 'المستخدمين', icon: Users },
          { id: 'realtime', label: 'الوقت الفعلي', icon: Zap },
        ].map(tab => (
          <button
            key={tab.id}
            onClick={() => setActiveTab(tab.id as any)}
            className={`flex items-center gap-2 px-4 py-2 rounded-lg whitespace-nowrap transition-colors ${
              activeTab === tab.id
                ? 'bg-emerald-100 text-emerald-700'
                : 'text-gray-600 hover:bg-gray-100'
            }`}
          >
            <tab.icon className="w-4 h-4" />
            {tab.label}
            {tab.id === 'realtime' && (
              <span className="w-2 h-2 bg-green-500 rounded-full animate-pulse" />
            )}
          </button>
        ))}
      </div>

      {/* تبويب نظرة عامة */}
      {activeTab === 'overview' && (
        <div className="space-y-6">
          {/* البطاقات الرئيسية */}
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <StatCard
              title="إجمالي المستخدمين"
              value={overview.totalUsers}
              change={12.5}
              changeLabel="من الشهر الماضي"
              icon={<Users className="w-6 h-6 text-blue-600" />}
              color="bg-blue-100"
            />
            <StatCard
              title="المستخدمين النشطين"
              value={overview.activeUsers}
              change={8.3}
              changeLabel="من الأسبوع الماضي"
              icon={<Activity className="w-6 h-6 text-green-600" />}
              color="bg-green-100"
            />
            <StatCard
              title="متوسط الجلسة"
              value={`${overview.avgSessionDuration} د`}
              change={5.2}
              icon={<Clock className="w-6 h-6 text-purple-600" />}
              color="bg-purple-100"
            />
            <StatCard
              title="معدل الاحتفاظ"
              value={`${overview.retentionRate}%`}
              change={2.1}
              icon={<Heart className="w-6 h-6 text-pink-600" />}
              color="bg-pink-100"
            />
          </div>

          {/* المستخدمين الجدد */}
          <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div className="bg-white p-5 rounded-xl shadow-sm border">
              <div className="flex items-center gap-3 mb-2">
                <div className="p-2 bg-emerald-100 rounded-lg">
                  <TrendingUp className="w-5 h-5 text-emerald-600" />
