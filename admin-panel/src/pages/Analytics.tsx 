// ==================== الأنواع ====================

interface OverviewStats {
  totalUsers: number;
  activeUsers: number;
  newUsersToday: number;
  newUsersThisWeek: number;
  newUsersThisMonth: number;
  totalSessions: number;
  avgSessionDuration: number; // بالدقائق
  avgDailySessions: number;
  retentionRate: number; // نسبة مئوية
  churnRate: number;
}

interface EngagementStats {
  totalAzkarRead: number;
  totalAzkarCompleted: number;
  avgAzkarPerUser: number;
  totalQuranPages: number;
  totalQuranMinutes: number;
  avgQuranPagesPerUser: number;
  totalPrayersLogged: number;
  avgPrayersPerUser: number;
  totalTasbihCount: number;
  totalDuasRead: number;
  totalShares: number;
}

interface ContentStats {
  mostReadAzkar: { id: string; name: string; count: number; percentage: number }[];
  mostReadSurahs: { id: number; name: string; count: number }[];
  mostUsedFeatures: { feature: string; name: string; count: number; percentage: number }[];
  peakUsageHours: { hour: number; count: number }[];
  peakUsageDays: { day: string; count: number }[];
}

interface UserDemographics {
  byCountry: { country: string; countryAr: string; count: number; percentage: number }[];
  byLanguage: { language: string; count: number; percentage: number }[];
  byPlatform: { platform: string; count: number; percentage: number }[];
  byAppVersion: { version: string; count: number; percentage: number }[];
  byDevice: { device: string; count: number }[];
}

interface GrowthData {
  daily: { date: string; users: number; sessions: number }[];
  weekly: { week: string; users: number; sessions: number }[];
  monthly: { month: string; users: number; sessions: number }[];
}

interface RealtimeData {
  activeNow: number;
  lastHourSessions: number;
  currentlyReading: {
    quran: number;
    azkar: number;
    dua: number;
  };
  recentEvents: {
    type: string;
    description: string;
    time: string;
    country?: string;
  }[];
}

type DateRange = 'today' | 'yesterday' | 'week' | 'month' | 'quarter' | 'year' | 'all' | 'custom';

